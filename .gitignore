# ── Python ────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyo
.Python

# ── Virtual Environment ───────────────────────────
.venv/
venv/
env/

# ── uv ────────────────────────────────────────────
.uv-cache/

# ── Data Files (too large for GitHub) ────────────
data/raw/
data/processed/
data/external/
*.csv
*.parquet

# ── Logs ──────────────────────────────────────────
logs/
*.log

# ── Environment & Secrets ─────────────────────────
.env
.env.*
!.env.example

# ── Jupyter / Marimo ──────────────────────────────
.ipynb_checkpoints/
*.ipynb
__marimo__/

# ── VS Code ───────────────────────────────────────
.vscode/
*.code-workspace

# ── OS Files ──────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── Testing & Coverage ────────────────────────────
.pytest_cache/
.coverage
htmlcov/
coverage.xml

# ── Ruff cache ────────────────────────────────────
.ruff_cache/

# ── Streamlit ─────────────────────────────────────
.streamlit/
__marimo__/

# ── Keep folder structure on GitHub ──────────────
!data/raw/.gitkeep
!data/processed/.gitkeep
!data/external/.gitkeep
!logs/.gitkeep

# ── DEMO BRANCH ───────────────────────────────────
# Artifacts are intentionally committed here.
# Do NOT copy this .gitignore back to main.